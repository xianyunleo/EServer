prefix=/Applications/EServer/Library/libpq
exec_prefix=${prefix}
libdir=${exec_prefix}/lib
includedir=${prefix}/include

Name: libpq
Description: PostgreSQL libpq library
URL: https://www.postgresql.org/
Version: 18.4
Requires: 
Requires.private: libssl, libcrypto, libcurl
Cflags: -I${includedir}
Libs: -L${libdir} -lpq
Libs.private: -L/Applications/EServer/Library/curl/lib -L/Applications/EServer/Library/icu/lib -L/Applications/EServer/Library/krb5/lib -L/Applications/EServer/Library/openssl@3.5/lib -lpgcommon -lpgport -lpq-oauth -lssl -lcrypto -lgssapi_krb5 -lm
