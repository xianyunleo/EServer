prefix=/Applications/EServer/Library/libxml2
exec_prefix=${prefix}
libdir=${exec_prefix}/lib
includedir=${prefix}/include
modules=1

Name: libXML
Version: 2.15.3
Description: libXML library version2.
Requires.private: 
Libs: -L${libdir} -lxml2 
Libs.private:    -L/Applications/EServer/Library/zlib/lib -lz -liconv  
Cflags: -I${includedir}/libxml2  
