prefix=/Applications/EServer/Library/xz
exec_prefix=/Applications/EServer/Library/xz
libdir=/Applications/EServer/Library/xz/lib
includedir=/Applications/EServer/Library/xz/include

Name: liblzma
Description: General purpose data compression library
License: 0BSD
URL: https://tukaani.org/xz/
Version: 5.8.3
Cflags: -I${includedir}
Cflags.private: -DLZMA_API_STATIC
Libs: -L${libdir} -llzma
Libs.private: -pthread -lpthread 
